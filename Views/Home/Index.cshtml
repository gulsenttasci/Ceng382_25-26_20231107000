@using Ceng382_25_26_202311070.Models
@model List<ProductCard>

@{
    ViewData["Title"] = "Home";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/site.css" asp-append-version="true" />

<section class="hero-panel py-5 border-bottom">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <span class="badge text-bg-primary mb-3">Step-by-step MVC demo</span>
                <h1 class="display-6 fw-bold mb-3">Learn HTML, CSS, and Bootstrap in ASP.NET Core MVC</h1>
                <p class="lead text-secondary mb-4">
                    This project intentionally keeps the UI simple: Bootstrap handles layout/components,
                    and a small <code>site.css</code> adds only app-specific styling.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Home" asp-action="ProductCatalog" class="btn btn-primary">
                         Open Product Catalog
                    </a>
                    <button class="btn btn-outline-secondary">Read Notes</button>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 info-card">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Learning Goals</h2>
                        <ul class="mb-0 ps-3">
                            <li>See Razor-generated HTML output</li>
                            <li>Use Bootstrap grid and utility classes</li>
                            <li>Add small, maintainable custom CSS</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
        

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold text-secondary">1. Hafta: HTML & CSS Sayfa İskeleti</h5>
            <small class="text-muted">Örnek Veri Tablosu (3 x 5)</small>
        </div>

        <div class="card-body p-0"> <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Öğrenci</th>
                            <th class="text-center">Vize</th>
                            <th class="text-center">Final</th>
                            <th class="text-center">Harf</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted">@p.Id</td>
                                <td class="fw-medium">@p.Name</td>
                                <td class="text-center">@p.Midterm</td>
                                <td class="text-center">@p.Final</td>
                                <td class="text-center">
                                    <span class="text-uppercase fw-bold">@p.Grade</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-2">
            <small class="text-muted">Not: Bu tablo 3 satır (öğrenci) ve 5 sütun içerir.</small>
        </div>
    </div>
</div>
   
</section>